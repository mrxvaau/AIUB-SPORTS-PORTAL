# ═══════════════════════════════════════════════════════════
# AIUB Sports Portal — Environment Configuration
# Version 3.0 — Production-Ready, Domain-Agnostic
# ═══════════════════════════════════════════════════════════
# Copy this to backend/.env and fill in your values.
# Lines with [PRODUCTION] must be updated before going live.

# ───────────────────────────────────────
# Server Configuration
# ───────────────────────────────────────
PORT=3000
NODE_ENV=development                    # [PRODUCTION] → production
SERVER_NAME=app-server-1                # [PRODUCTION] → unique per server (app-server-1, app-server-2)
APP_VERSION=3.0.0
TRUST_PROXY=1                           # 1 = trust first proxy (Cloudflare/Nginx)

# ───────────────────────────────────────
# URLs & Domain Configuration
# ───────────────────────────────────────
# [PRODUCTION] Update these when domain is purchased:
#   FRONTEND_URL=https://sportsportal.com
#   CORS_ORIGINS=https://sportsportal.com,https://admin.sportsportal.com
#   COOKIE_DOMAIN=.sportsportal.com

FRONTEND_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3001,http://localhost:3000
CORS_ORIGIN=http://localhost:3001       # Legacy single origin (backward compat)
COOKIE_DOMAIN=localhost

# ───────────────────────────────────────
# Supabase Configuration
# ───────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here    # Required for backend

# ───────────────────────────────────────
# Authentication — JWT
# ───────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING         # [PRODUCTION] Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_TIMEOUT=3600000                                  # 1 hour in ms

# ───────────────────────────────────────
# Authentication — Microsoft Azure AD OAuth
# ───────────────────────────────────────
AZURE_TENANT_ID=your_tenant_id
AZURE_CLIENT_ID=your_client_id
AZURE_CLIENT_SECRET=your_client_secret
AZURE_REDIRECT_URI=http://localhost:3001/callback        # [PRODUCTION] → https://sportsportal.com/callback

# ───────────────────────────────────────
# Email Validation
# ───────────────────────────────────────
ALLOWED_EMAIL_DOMAIN=@student.aiub.edu

# ───────────────────────────────────────
# Logging
# ───────────────────────────────────────
LOG_LEVEL=debug                         # [PRODUCTION] → info

# ───────────────────────────────────────
# Worker Configuration (Multi-Server)
# ───────────────────────────────────────
# Only set to true on ONE server in a multi-server deployment.
# This server runs background jobs (cron, cleanup, scheduled tasks).
WORKER_ENABLED=true                     # [PRODUCTION] → true on server-1 ONLY

# ───────────────────────────────────────
# Graceful Shutdown
# ───────────────────────────────────────
SHUTDOWN_TIMEOUT=10000                  # ms to wait for active requests to drain

# ───────────────────────────────────────
# Application
# ───────────────────────────────────────
APP_NAME=AIUB Sports Portal

# ───────────────────────────────────────
# Tunneling (Development Only)
# ───────────────────────────────────────
# TUNNEL_FRONTEND_URL=https://your-tunnel.loca.lt
